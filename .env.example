# Copy this file to .env and fill in your values
# .env is listed in .gitignore — it will never be pushed to GitHub

# Your GitHub username
GITHUB_USER=ryankcampbell

# A GitHub Personal Access Token with repo write access
# Create one at: github.com/settings/tokens/new
# Scopes needed: repo (full control of private repositories)
# NEVER paste this token anywhere except this file
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The remote repo URL (will be set automatically by setup)
GITHUB_REPO=nwa-physics-navigator
