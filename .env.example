# Copy this file to .env and fill in your values
# .env is listed in .gitignore — it will never be pushed to GitHub

# Path to your Google service account credentials JSON file
# (download from Google Cloud Console → IAM → Service Accounts → Keys)
GOOGLE_KEY_FILE=credentials.json

# Google Drive folder ID — copy from your Drive folder URL:
# https://drive.google.com/drive/folders/THIS_PART_HERE
DRIVE_FOLDER_ID=your_folder_id_here

# GitHub personal access token (repo scope)
# Generate at: github.com → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=ghp_your_token_here

# Your GitHub username and repo name
GITHUB_USER=ryankcampbell
GITHUB_REPO=adv-physics-wiki
